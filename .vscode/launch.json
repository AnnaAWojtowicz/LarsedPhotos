{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug React in Chrome (dev)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/src",
      "sourceMaps": true,
      "skipFiles": ["<node_internals>/**"],
      "runtimeExecutable": "/usr/bin/chromium",
      "preLaunchTask": "npm: dev"
    }
  ]
}
