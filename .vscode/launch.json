{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug React in Firefox (dev)",
      "type": "firefox",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/src",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "preLaunchTask": "npm: dev",
      "postDebugTask": "kill npm: dev",
      "pathMappings": [
        {
          "url": "http://localhost:5173/src",
          "path": "${workspaceFolder}/src"
        }
      ]
    }
  ]
}
